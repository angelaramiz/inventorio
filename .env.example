# SUPABASE_URL: The URL of your Supabase project
# SUPABASE_KEY: The public anon key or service role key
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_KEY="your_supabase_public_key_here"

# APP_URL: The URL where this applet is hosted.
# For Render: https://your-app-name.onrender.com
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="https://your-app-name.onrender.com"

# CORS Configuration (Production only)
# Comma-separated list of allowed origins
ALLOWED_ORIGINS="http://localhost:3000,https://your-app-name.onrender.com"

# Node Environment
NODE_ENV="development"

# Server Port
PORT="3000"

