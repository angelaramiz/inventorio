# Production Environment Variables for Render
# Copy these values to Render dashboard environment variables

NODE_ENV=production

# Supabase Configuration
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_key_here

# CORS - Allowed origins (comma-separated)
# These should be set to your actual Render domain
ALLOWED_ORIGINS=https://inventario-app.onrender.com

# Server Port (Usually 3000, but Render may override)
PORT=3000
